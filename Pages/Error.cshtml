@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="cv-card">
    <h1 class="cv-h1">Something went wrong</h1>
    @if (Model.ShowRequestId)
    {
        <p class="cv-muted">Request ID: <code>@Model.RequestId</code></p>
    }
    <a class="cv-btn cv-btn-primary" asp-page="/Index">Home</a>
</div>
