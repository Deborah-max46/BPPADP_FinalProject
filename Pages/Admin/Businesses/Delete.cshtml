@page "{id:int}"
@model ConsumersVoiceSystemPrototype.Pages.Admin.Businesses.DeleteModel
@{
    ViewData["Title"] = "Delete business";
}

<div class="cv-card cv-card-narrow">
    <h1 class="cv-h1">Delete business</h1>
    <p>Delete <strong>@Model.BusinessName</strong>?</p>
    <form method="post">
        <button type="submit" class="cv-btn cv-btn-primary">Delete</button>
        <a class="cv-btn cv-btn-outline" asp-page="Index">Cancel</a>
    </form>
</div>
