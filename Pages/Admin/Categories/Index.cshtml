@page
@model ConsumersVoiceSystemPrototype.Pages.Admin.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
}

<div class="cv-card cv-card-wide">
    <div class="cv-toolbar">
        <h1 class="cv-h1">Categories</h1>
        <a class="cv-btn cv-btn-primary" asp-page="Create">Add category</a>
    </div>
    <table class="cv-table">
        <thead>
            <tr><th>Name</th><th>Complaints</th><th></th></tr>
        </thead>
        <tbody>
        @foreach (var r in Model.Rows)
        {
            <tr>
                <td>@r.Name</td>
                <td>@r.UsageCount</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@r.Id">Edit</a>
                    @if (r.UsageCount == 0)
                    {
                        <a asp-page="Delete" asp-route-id="@r.Id" class="cv-link-btn cv-danger">Delete</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
