@page
@model ConsumersVoiceSystemPrototype.Pages.Advocate.ComplaintsModel
@{
    ViewData["Title"] = "All complaints";
}

<div class="cv-card cv-card-wide">
    <div class="cv-toolbar">
        <h1 class="cv-h1">Complaint queue</h1>
        <form method="get" class="cv-search-form">
            <input type="search" name="filter" value="@Model.Filter" placeholder="Search title, consumer, category" class="cv-input" />
            <button type="submit" class="cv-btn cv-btn-outline">Filter</button>
        </form>
    </div>
    <table class="cv-table">
        <thead>
            <tr>
                <th>Ref</th>
                <th>Title</th>
                <th>Category</th>
                <th>Business</th>
                <th>Consumer</th>
                <th>Advocate</th>
                <th>Status</th>
                <th>Updated</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in Model.Rows)
        {
            <tr>
                <td>#@r.CaseNumber</td>
                <td>@r.Title</td>
                <td>@r.CategoryName</td>
                <td>@(r.BusinessName ?? "—")</td>
                <td>@r.ConsumerName</td>
                <td>
                    @if (r.Unassigned)
                    {
                        <span class="cv-badge-soft">Unassigned</span>
                    }
                    else
                    {
                        @r.AdvocateName
                    }
                </td>
                <td>@r.Status</td>
                <td>@r.UpdatedAt.ToLocalTime().ToString("g")</td>
                <td><a asp-page="/Complaints/Details" asp-route-id="@r.CaseNumber">Open</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
